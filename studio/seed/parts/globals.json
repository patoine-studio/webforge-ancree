    {
      "type": "legalPage",
      "content": {
        "_id": "legalPage-conditions-fr",
        "language": "fr",
        "title": "Conditions d'utilisation",
        "sections": [
          {
            "_key": "cond-acceptation",
            "_type": "legalSection",
            "title": "Acceptation des conditions",
            "body": [
              {
                "_key": "cond-acceptation-p1",
                "_type": "legalParagraph",
                "text": "En consultant ce site, vous acceptez les présentes conditions d'utilisation. Si vous n'y consentez pas, veuillez ne pas utiliser le site. Rempart Extermination peut modifier ces conditions en tout temps, et la version en vigueur est celle affichée sur cette page."
              }
            ]
          },
          {
            "_key": "cond-utilisation",
            "_type": "legalSection",
            "title": "Utilisation du site",
            "body": [
              {
                "_key": "cond-utilisation-p1",
                "_type": "legalParagraph",
                "text": "Ce site est offert à des fins d'information sur nos services d'extermination. Vous vous engagez à l'utiliser de façon licite et respectueuse."
              },
              {
                "_key": "cond-utilisation-l1",
                "_type": "legalList",
                "items": [
                  "Ne pas nuire au fonctionnement du site ni à sa sécurité.",
                  "Ne pas tenter d'accéder à des données qui ne vous sont pas destinées.",
                  "Réserver le contenu à un usage personnel et non commercial."
                ]
              }
            ]
          },
          {
            "_key": "cond-propriete",
            "_type": "legalSection",
            "title": "Propriété intellectuelle",
            "body": [
              {
                "_key": "cond-propriete-p1",
                "_type": "legalParagraph",
                "text": "Le contenu de ce site, dont les textes, les images, le logo et la présentation, appartient à Rempart Extermination ou à ses partenaires. Toute reproduction ou diffusion sans autorisation écrite préalable est interdite."
              }
            ]
          },
          {
            "_key": "cond-responsabilite",
            "_type": "legalSection",
            "title": "Limitation de responsabilité",
            "body": [
              {
                "_key": "cond-responsabilite-p1",
                "_type": "legalParagraph",
                "text": "Le contenu du site est fourni à titre indicatif. Rempart Extermination s'efforce de le tenir à jour, sans garantir l'exactitude ou l'exhaustivité de toute l'information. L'entreprise ne peut être tenue responsable d'un dommage découlant de l'usage du site."
              }
            ]
          },
          {
            "_key": "cond-estimations",
            "_type": "legalSection",
            "title": "Estimations et services",
            "body": [
              {
                "_key": "cond-estimations-p1",
                "_type": "legalParagraph",
                "text": "Les prix et les délais évoqués sur le site sont donnés à titre indicatif. Seule l'estimation écrite remise après une évaluation fait foi. La portée des travaux, la garantie et les conditions de service sont précisées dans ce document."
              }
            ]
          },
          {
            "_key": "cond-droit",
            "_type": "legalSection",
            "title": "Droit applicable",
            "body": [
              {
                "_key": "cond-droit-p1",
                "_type": "legalParagraph",
                "text": "Les présentes conditions sont régies par les lois en vigueur au Québec et au Canada. Tout litige relève des tribunaux compétents du district judiciaire où se trouve le siège de l'entreprise."
              }
            ]
          },
          {
            "_key": "cond-coordonnees",
            "_type": "legalSection",
            "title": "Pour nous joindre",
            "body": [
              {
                "_key": "cond-coordonnees-p1",
                "_type": "legalParagraph",
                "text": "Pour toute question sur ces conditions, écrivez à bonjour@rempart-extermination.ca ou composez le 450 555 0199."
              },
              {
                "_key": "cond-coordonnees-todo",
                "_type": "legalTodo",
                "text": "Coordonnées légales complètes de l'entreprise (raison sociale, numéro d'entreprise du Québec, adresse du siège) à confirmer par le client."
              }
            ]
          }
        ]
      }
    },
    {
      "type": "legalPage",
      "content": {
        "_id": "legalPage-conditions-en",
        "language": "en",
        "title": "Terms of Use",
        "sections": [
          {
            "_key": "cond-acceptation",
            "_type": "legalSection",
            "title": "Acceptance of the terms",
            "body": [
              {
                "_key": "cond-acceptation-p1",
                "_type": "legalParagraph",
                "text": "By using this site, you accept these terms of use. If you do not agree to them, please do not use the site. Rempart Extermination may amend these terms at any time, and the version in effect is the one posted on this page."
              }
            ]
          },
          {
            "_key": "cond-utilisation",
            "_type": "legalSection",
            "title": "Use of the site",
            "body": [
              {
                "_key": "cond-utilisation-p1",
                "_type": "legalParagraph",
                "text": "This site is provided to inform you about our pest control services. You agree to use it in a lawful and respectful manner."
              },
              {
                "_key": "cond-utilisation-l1",
                "_type": "legalList",
                "items": [
                  "Do not interfere with the operation or the security of the site.",
                  "Do not attempt to access data that is not intended for you.",
                  "Keep the content for personal, non-commercial use."
                ]
              }
            ]
          },
          {
            "_key": "cond-propriete",
            "_type": "legalSection",
            "title": "Intellectual property",
            "body": [
              {
                "_key": "cond-propriete-p1",
                "_type": "legalParagraph",
                "text": "The content of this site, including the text, images, logo and layout, belongs to Rempart Extermination or its partners. Any reproduction or distribution without prior written authorization is prohibited."
              }
            ]
          },
          {
            "_key": "cond-responsabilite",
            "_type": "legalSection",
            "title": "Limitation of liability",
            "body": [
              {
                "_key": "cond-responsabilite-p1",
                "_type": "legalParagraph",
                "text": "The content of the site is provided for information purposes. Rempart Extermination strives to keep it up to date, without guaranteeing the accuracy or completeness of all information. The company cannot be held liable for any damage arising from use of the site."
              }
            ]
          },
          {
            "_key": "cond-estimations",
            "_type": "legalSection",
            "title": "Estimates and services",
            "body": [
              {
                "_key": "cond-estimations-p1",
                "_type": "legalParagraph",
                "text": "Prices and timelines mentioned on the site are provided for information only. Only the written estimate issued after an assessment is binding. The scope of work, the guarantee and the service conditions are set out in that document."
              }
            ]
          },
          {
            "_key": "cond-droit",
            "_type": "legalSection",
            "title": "Governing law",
            "body": [
              {
                "_key": "cond-droit-p1",
                "_type": "legalParagraph",
                "text": "These terms are governed by the laws in force in Quebec and Canada. Any dispute falls under the jurisdiction of the competent courts of the judicial district where the company's head office is located."
              }
            ]
          },
          {
            "_key": "cond-coordonnees",
            "_type": "legalSection",
            "title": "How to reach us",
            "body": [
              {
                "_key": "cond-coordonnees-p1",
                "_type": "legalParagraph",
                "text": "For any question about these terms, write to bonjour@rempart-extermination.ca or call 450 555 0199."
              },
              {
                "_key": "cond-coordonnees-todo",
                "_type": "legalTodo",
                "text": "Complete legal details of the company (legal name, Quebec enterprise number, head office address) to be confirmed by the client."
              }
            ]
          }
        ]
      }
    },
    {
      "type": "legalPage",
      "content": {
        "_id": "legalPage-confidentialite-fr",
        "language": "fr",
        "title": "Politique de confidentialité",
        "sections": [
          {
            "_key": "conf-collecte",
            "_type": "legalSection",
            "title": "Renseignements que nous recueillons",
            "body": [
              {
                "_key": "conf-collecte-p1",
                "_type": "legalParagraph",
                "text": "Lorsque vous communiquez avec nous, nous recueillons uniquement les renseignements que vous nous transmettez de votre plein gré."
              },
              {
                "_key": "conf-collecte-l1",
                "_type": "legalList",
                "items": [
                  "Votre nom.",
                  "Vos coordonnées, soit le téléphone et le courriel.",
                  "Le contenu de votre message ou de votre demande."
                ]
              }
            ]
          },
          {
            "_key": "conf-utilisation",
            "_type": "legalSection",
            "title": "Utilisation des renseignements",
            "body": [
              {
                "_key": "conf-utilisation-p1",
                "_type": "legalParagraph",
                "text": "Nous utilisons vos renseignements pour répondre à vos demandes, préparer une estimation et planifier une visite. Nous ne nous en servons pas à d'autres fins sans votre consentement."
              }
            ]
          },
          {
            "_key": "conf-partage",
            "_type": "legalSection",
            "title": "Partage des renseignements",
            "body": [
              {
                "_key": "conf-partage-p1",
                "_type": "legalParagraph",
                "text": "Nous ne vendons ni ne louons vos renseignements. Nous pouvons les confier à des sous-traitants strictement nécessaires à la prestation du service, qui sont tenus de les protéger."
              }
            ]
          },
          {
            "_key": "conf-conservation",
            "_type": "legalSection",
            "title": "Conservation et sécurité",
            "body": [
              {
                "_key": "conf-conservation-p1",
                "_type": "legalParagraph",
                "text": "Nous conservons vos renseignements le temps requis pour traiter votre demande et respecter nos obligations. Nous prenons des mesures raisonnables pour les protéger contre la perte, le vol et l'accès non autorisé."
              }
            ]
          },
          {
            "_key": "conf-droits",
            "_type": "legalSection",
            "title": "Vos droits",
            "body": [
              {
                "_key": "conf-droits-p1",
                "_type": "legalParagraph",
                "text": "Conformément à la loi, vous disposez de droits sur vos renseignements personnels."
              },
              {
                "_key": "conf-droits-l1",
                "_type": "legalList",
                "items": [
                  "Accéder aux renseignements que nous détenons sur vous.",
                  "Faire rectifier un renseignement inexact.",
                  "Retirer votre consentement en tout temps."
                ]
              }
            ]
          },
          {
            "_key": "conf-responsable",
            "_type": "legalSection",
            "title": "Responsable de la protection des renseignements personnels",
            "body": [
              {
                "_key": "conf-responsable-p1",
                "_type": "legalParagraph",
                "text": "Une personne responsable de la protection des renseignements personnels veille au respect de la présente politique et traite les demandes liées à vos droits."
              },
              {
                "_key": "conf-responsable-todo",
                "_type": "legalTodo",
                "text": "Nom et coordonnées du responsable de la protection des renseignements personnels à fournir par le client, conformément à la Loi 25."
              }
            ]
          },
          {
            "_key": "conf-temoins",
            "_type": "legalSection",
            "title": "Témoins de connexion",
            "body": [
              {
                "_key": "conf-temoins-p1",
                "_type": "legalParagraph",
                "text": "Ce site peut utiliser des témoins pour assurer son bon fonctionnement et mesurer son audience de façon globale. Vous pouvez configurer votre navigateur pour les refuser."
              }
            ]
          },
          {
            "_key": "conf-modifications",
            "_type": "legalSection",
            "title": "Modifications",
            "body": [
              {
                "_key": "conf-modifications-p1",
                "_type": "legalParagraph",
                "text": "Nous pouvons modifier cette politique pour refléter un changement à nos pratiques ou à la loi. La version en vigueur est celle affichée sur cette page."
              }
            ]
          }
        ]
      }
    },
    {
      "type": "legalPage",
      "content": {
        "_id": "legalPage-confidentialite-en",
        "language": "en",
        "title": "Privacy Policy",
        "sections": [
          {
            "_key": "conf-collecte",
            "_type": "legalSection",
            "title": "Information we collect",
            "body": [
              {
                "_key": "conf-collecte-p1",
                "_type": "legalParagraph",
                "text": "When you contact us, we collect only the information that you choose to share with us."
              },
              {
                "_key": "conf-collecte-l1",
                "_type": "legalList",
                "items": [
                  "Your name.",
                  "Your contact details, namely phone and email.",
                  "The content of your message or request."
                ]
              }
            ]
          },
          {
            "_key": "conf-utilisation",
            "_type": "legalSection",
            "title": "Use of the information",
            "body": [
              {
                "_key": "conf-utilisation-p1",
                "_type": "legalParagraph",
                "text": "We use your information to respond to your requests, prepare an estimate and schedule a visit. We do not use it for other purposes without your consent."
              }
            ]
          },
          {
            "_key": "conf-partage",
            "_type": "legalSection",
            "title": "Sharing of the information",
            "body": [
              {
                "_key": "conf-partage-p1",
                "_type": "legalParagraph",
                "text": "We do not sell or rent your information. We may entrust it to service providers who are strictly necessary to deliver the service and who are required to protect it."
              }
            ]
          },
          {
            "_key": "conf-conservation",
            "_type": "legalSection",
            "title": "Retention and security",
            "body": [
              {
                "_key": "conf-conservation-p1",
                "_type": "legalParagraph",
                "text": "We keep your information for as long as needed to handle your request and meet our obligations. We take reasonable measures to protect it against loss, theft and unauthorized access."
              }
            ]
          },
          {
            "_key": "conf-droits",
            "_type": "legalSection",
            "title": "Your rights",
            "body": [
              {
                "_key": "conf-droits-p1",
                "_type": "legalParagraph",
                "text": "In accordance with the law, you hold rights over your personal information."
              },
              {
                "_key": "conf-droits-l1",
                "_type": "legalList",
                "items": [
                  "Access the information we hold about you.",
                  "Have inaccurate information corrected.",
                  "Withdraw your consent at any time."
                ]
              }
            ]
          },
          {
            "_key": "conf-responsable",
            "_type": "legalSection",
            "title": "Person in charge of personal information protection",
            "body": [
              {
                "_key": "conf-responsable-p1",
                "_type": "legalParagraph",
                "text": "A person in charge of personal information protection ensures compliance with this policy and handles requests related to your rights."
              },
              {
                "_key": "conf-responsable-todo",
                "_type": "legalTodo",
                "text": "Name and contact details of the person in charge of personal information protection to be provided by the client, in accordance with Quebec's Law 25."
              }
            ]
          },
          {
            "_key": "conf-temoins",
            "_type": "legalSection",
            "title": "Cookies",
            "body": [
              {
                "_key": "conf-temoins-p1",
                "_type": "legalParagraph",
                "text": "This site may use cookies to ensure that it works properly and to measure its audience in aggregate. You can set your browser to refuse them."
              }
            ]
          },
          {
            "_key": "conf-modifications",
            "_type": "legalSection",
            "title": "Changes",
            "body": [
              {
                "_key": "conf-modifications-p1",
                "_type": "legalParagraph",
                "text": "We may amend this policy to reflect a change in our practices or in the law. The version in effect is the one posted on this page."
              }
            ]
          }
        ]
      }
    }
